# AI Translation API Configuration
# Copy this file to .env and fill in your values

# API endpoint URL (OpenAI-compatible endpoint)
# Examples:
#   OpenAI: https://api.openai.com/v1/chat/completions
#   Azure: https://your-resource.openai.azure.com/openai/deployments/your-deployment/chat/completions?api-version=2024-02-15-preview
#   Local: http://localhost:1234/v1/chat/completions
VITE_AI_API_URL=

# API Key for authentication
VITE_AI_API_KEY=

# Model identifier
# Examples: gpt-4o, gpt-4o-mini, gpt-3.5-turbo, claude-3-sonnet, etc.
VITE_AI_MODEL=gpt-4o-mini
